{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "core-state-pack.schema.json",
  "title": "CoreStatePack",
  "description": "Schema for the compact canonical snapshot generated by generate-core-state-pack.mjs",
  "type": "object",
  "required": [
    "generatedAt",
    "repoRoot",
    "canonicalStateFile",
    "executionPlanFile",
    "backlogFile",
    "wave2",
    "coreFiles",
    "recentRepoState",
    "apiSurfaceHints",
    "testSurfaceHints",
    "docSyncSummary"
  ],
  "additionalProperties": false,
  "properties": {
    "generatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when this pack was generated"
    },
    "repoRoot": {
      "type": "string",
      "description": "Absolute path to the repository root"
    },
    "canonicalStateFile": {
      "type": "string",
      "description": "Path to wave2-canonical-state.json"
    },
    "executionPlanFile": {
      "type": "string",
      "description": "Path to v2-wave2-execution-plan.md"
    },
    "backlogFile": {
      "type": "string",
      "description": "Path to backlog-unified-status-and-order.md"
    },
    "wave2": {
      "type": "object",
      "required": [
        "totalTasks",
        "currentScanPoint",
        "activeTask",
        "previousTask",
        "stateCounts"
      ],
      "additionalProperties": false,
      "properties": {
        "totalTasks": {
          "type": "integer",
          "minimum": 1
        },
        "currentScanPoint": {
          "type": "integer",
          "minimum": 1,
          "description": "Lowest execution_order whose state is not trueGreen (the active task)"
        },
        "activeTask": {
          "type": "object",
          "required": ["execution_order", "taskName", "recordedState"],
          "additionalProperties": false,
          "properties": {
            "execution_order": { "type": "integer" },
            "taskName": { "type": "string" },
            "recordedState": { "type": "string" }
          }
        },
        "previousTask": {
          "type": "object",
          "required": ["execution_order", "taskName", "recordedState"],
          "additionalProperties": false,
          "properties": {
            "execution_order": { "type": ["integer", "null"] },
            "taskName": { "type": ["string", "null"] },
            "recordedState": { "type": ["string", "null"] }
          }
        },
        "stateCounts": {
          "type": "object",
          "required": ["trueGreen", "blocked", "bridge-deferred", "in-progress"],
          "additionalProperties": false,
          "properties": {
            "trueGreen": { "type": "integer", "minimum": 0 },
            "blocked": { "type": "integer", "minimum": 0 },
            "bridge-deferred": { "type": "integer", "minimum": 0 },
            "in-progress": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "coreFiles": {
      "type": "array",
      "description": "File metadata and hashes for core high-risk files",
      "items": {
        "type": "object",
        "required": ["path", "exists", "size", "mtimeMs", "sha256"],
        "additionalProperties": false,
        "properties": {
          "path": { "type": "string" },
          "exists": { "type": "boolean" },
          "size": { "type": "integer", "minimum": 0 },
          "mtimeMs": { "type": "number" },
          "sha256": { "type": "string" }
        }
      }
    },
    "recentRepoState": {
      "type": "object",
      "required": ["gitAvailable", "workingTreeDirty", "changedFiles", "untrackedFiles"],
      "additionalProperties": false,
      "properties": {
        "gitAvailable": { "type": "boolean" },
        "workingTreeDirty": { "type": "boolean" },
        "changedFiles": {
          "type": "array",
          "items": { "type": "string" }
        },
        "untrackedFiles": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "apiSurfaceHints": {
      "type": "object",
      "required": ["serverRoutesDetected", "keyRuntimeModules"],
      "additionalProperties": false,
      "properties": {
        "serverRoutesDetected": {
          "type": "array",
          "items": { "type": "string" }
        },
        "keyRuntimeModules": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "testSurfaceHints": {
      "type": "object",
      "required": ["relevantTestsDetected"],
      "additionalProperties": false,
      "properties": {
        "relevantTestsDetected": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "docSyncSummary": {
      "type": "object",
      "required": [
        "canonicalStateReadable",
        "executionPlanReadable",
        "backlogReadable",
        "taskNameExecutionOrderConsistent"
      ],
      "additionalProperties": false,
      "properties": {
        "canonicalStateReadable": { "type": "boolean" },
        "executionPlanReadable": { "type": "boolean" },
        "backlogReadable": { "type": "boolean" },
        "taskNameExecutionOrderConsistent": { "type": "boolean" }
      }
    }
  }
}
